{"type":"hook.start","data":{"hookInvocationId":"1427c141-2b42-40a3-8981-dd44bd5b5dc9","hookType":"postToolUse","input":{"sessionId":"df55ad11-2625-4c57-b8bd-4d7739babaaa","timestamp":1777599965076,"cwd":"/tmp/sv-59df059531864bebb720d57429597d23","toolName":"view","toolArgs":{"path":"/tmp/sv-59df059531864bebb720d57429597d23/ShippingCalculatorTests.cs"},"toolResult":{"resultType":"success","textResultForLlm":"1. using Microsoft.VisualStudio.TestTools.UnitTesting;\n2. namespace Contoso.Shipping.Tests;\n3. \n4. [TestClass]\n5. public class ShippingCalculatorTests\n6. {\n7.     [TestMethod]\n8.     public void CalculateShipping_StandardDelivery_Returns5()\n9.     {\n10.         Assert.AreEqual(5.00m, CalculateShipping(\"standard\", 1.0));\n11.     }\n12. \n13.     [TestMethod]\n14.     public void CalculateShipping_ExpressDelivery_Returns15()\n15.     {\n16.         Assert.AreEqual(15.00m, CalculateShipping(\"express\", 1.0));\n17.     }\n18. \n19.     private static decimal CalculateShipping(string method, double weightKg)\n20.     {\n21.         return method switch\n22.         {\n23.             \"standard\" => 5.00m,\n24.             \"express\" => 10.00m,\n25.             _ => throw new ArgumentException(\"Unknown shipping method\")\n26.         };\n27.     }\n28. }\n29. ","toolTelemetry":{"properties":{"command":"view","options":"{\"truncateBasedOn\":\"tokenCount\",\"truncateStyle\":\"middle\"}","inputs":"[\"path\",\"command\"]","resolvedPathAgainstCwd":"false","fileExtension":"[\".cs\"]","viewType":"file"},"metrics":{"resultLength":844,"resultForLlmLength":844,"responseTokenLimit":42000},"restrictedProperties":{}},"sessionLog":"\ndiff --git a/tmp/sv-59df059531864bebb720d57429597d23/ShippingCalculatorTests.cs b/tmp/sv-59df059531864bebb720d57429597d23/ShippingCalculatorTests.cs\nindex 0000000..0000000 100644\n--- a/tmp/sv-59df059531864bebb720d57429597d23/ShippingCalculatorTests.cs\n+++ b/tmp/sv-59df059531864bebb720d57429597d23/ShippingCalculatorTests.cs\n@@ -1,29 